# ============================================
# 书法考级报名系统 - .dockerignore
# 构建镜像时忽略的文件
# ============================================

# 依赖和构建产物
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 编辑器和IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统
.DS_Store
Thumbs.db
ehthumbs.db

# 版本控制
.git/
.gitignore
.github/

# 文档
*.md
.trae/
README.md
README.preflight.md

# 脚本和工具
scripts/
*.py
*.sh
*.bat
*.ps1

# 测试
coverage/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# 环境变量
.env
.env.local
.env.*.local

# 临时文件
*.tmp
*.temp
.cache/
.trae-preflight.json
